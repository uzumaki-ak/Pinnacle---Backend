




# ///

# Server
PORT=8000
ENVIRONMENT=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# LLM APIs
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx
EURON_API_KEY=your-euron-api-key
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxx
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_PROVIDER=local

# Transcription
USE_WHISPER_API=true
WHISPER_API_KEY=${OPENAI_API_KEY}
WHISPER_MODEL=base

# OCR
TESSERACT_PATH=/usr/bin/tesseract

# Features
ENABLE_AUTO_TRANSCRIPTION=true
ENABLE_AUTO_OCR=true
ENABLE_AUTO_TAGGING=true
ENABLE_DUPLICATE_DETECTION=true
MAX_FILE_SIZE_MB=50

# Security
SECRET_KEY=your-secret-key-change-in-production